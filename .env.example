# ═══════════════════════════════════════════════════════════════════════
#  SOL-ARB-BOT — Environment Configuration
#  Copy to .env and fill in your values before running.
#  All values can also be passed as CLI flags (--rpc-url, etc.)
# ═══════════════════════════════════════════════════════════════════════

# ── RPC ──────────────────────────────────────────────────────────────
# Primary Solana JSON-RPC endpoint. Use a dedicated node or paid provider
# (Helius, Triton, QuickNode, Tatum) — public endpoints rate-limit aggressively.
# Format: https://your-node.example.com  (no trailing slash)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Fallback RPC used if the primary fails during blockhash fetch or tx send.
# Defaults to the public Solana mainnet endpoint (low rate limits).
FALLBACK_RPC_URL=https://api.mainnet-beta.solana.com

# ── gRPC / Yellowstone ───────────────────────────────────────────────
# Yellowstone gRPC endpoint for real-time transaction streaming.
# Must use https:// (TLS required by all major providers).
# Providers: Tatum (solana-mainnet-grpc.gateway.tatum.io), 
#            Helius (grpc.helius.dev), Triton (your-region.rpc.triton.one),
#            QuickNode (your-endpoint.quiknode.pro)
#
# ⚠️  Common mistakes that cause connection failures:
#   - Using http:// instead of https://
#   - Including a trailing slash
#   - Omitting the port (default gRPC port is usually 443 or 10000)
#
# Tatum example:   https://solana-mainnet-grpc.gateway.tatum.io:443
# Helius example:  https://mainnet.helius-rpc.com:443
# Triton example:  https://YOUR_NAME.solana-mainnet.quiknode.pro:10000
GRPC_ENDPOINT=https://solana-mainnet-grpc.gateway.tatum.io:443

# Auth token for the gRPC endpoint (x-token header).
# Required by Tatum, Helius, Triton, and most paid providers.
# Leave empty only if your endpoint does not require authentication.
GRPC_X_TOKEN=your_grpc_auth_token_here

# ── Wallet ───────────────────────────────────────────────────────────
# Base58-encoded keypair of the fee-payer wallet.
# This wallet pays tx fees and Jito tips — keep it funded (~0.1 SOL min).
# Generate with: solana-keygen new --outfile keypair.json
# Export base58:  cat keypair.json | python3 -c "import sys,json,base58; print(base58.b58encode(bytes(json.load(sys.stdin))).decode())"
FEE_PAYER_KEYPAIR_BASE58=your_base58_encoded_keypair_here

# ── Arbitrage Thresholds ─────────────────────────────────────────────
# Minimum net profit (after fees + tips) required to execute a trade (SOL).
MIN_PROFIT_SOL=0.01

# Maximum flash loan size to attempt per opportunity (SOL).
MAX_LOAN_SOL=50.0

# Slippage tolerance per swap leg in basis points (1 bps = 0.01%).
# 100 = 1%, 50 = 0.5%. Lower = safer but more quotes rejected.
SLIPPAGE_BPS=100

# ── Jupiter ──────────────────────────────────────────────────────────
# URL of your local Jupiter V6 self-hosted API instance.
# Self-host guide: https://station.jup.ag/docs/apis/self-hosted
# Do NOT use the public api.jup.ag in production — rate limits will
# kill your scanner throughput.
JUPITER_API_URL=http://127.0.0.1:8080

# ── Transaction Tuning ───────────────────────────────────────────────
# Compute unit budget per transaction. 400k is safe for 2-leg arbs.
COMPUTE_UNIT_LIMIT=400000

# Base priority fee in micro-lamports per compute unit.
# The executor dynamically raises this to the p75 of recent fees,
# capped at 10× this value.
PRIORITY_FEE_MICRO_LAMPORTS=50000

# Number of times to retry a failed RPC send before giving up.
MAX_TX_RETRIES=2

# ── Scanner & Executor ───────────────────────────────────────────────
# Max number of opportunities evaluated concurrently.
# Each slot holds a Jupiter quote pair (~2 HTTP calls). Scale with
# your Jupiter API capacity and available CPU.
# This also limits the number of concurrent transaction executions.
SCANNER_MAX_CONCURRENCY=32

# Maximum age of an opportunity in slots before it is discarded.
MAX_OPPORTUNITY_AGE_SLOTS=20

# ── Jito ─────────────────────────────────────────────────────────────
# Enable Jito bundle submission (recommended — protects against front-running).
# When false, txs are sent via standard RPC and visible in the mempool.
JITO_ENABLED=true

# Jito block engine URL. Use the region closest to your RPC node.
# mainnet:        https://mainnet.block-engine.jito.wtf
# amsterdam:      https://amsterdam.mainnet.block-engine.jito.wtf
# frankfurt:      https://frankfurt.mainnet.block-engine.jito.wtf
# new york:       https://ny.mainnet.block-engine.jito.wtf
# tokyo:          https://tokyo.mainnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# Jito tip amount in lamports paid to the validator per bundle.
# Higher tips increase landing probability during congestion.
# 10_000 = 0.00001 SOL. Typical competitive range: 10_000–100_000.
JITO_TIP_LAMPORTS=10000

# Fraction of expected profit to pay as a Jito tip (0.0 to 1.0).
# If set, this overrides JITO_TIP_LAMPORTS if the calculated tip is higher.
JITO_TIP_PROFIT_FRACTION=0.1

# ── TUI ──────────────────────────────────────────────────────────────
# Set to true to disable the interactive TUI and log to stdout instead.
# Useful for running headless in a systemd service or Docker container.
NO_TUI=false

# Target render frames per second for the TUI (1–60).
# Lower values reduce CPU usage; 10 is a good default for 24/7 operation.
TUI_FPS=10

# Enable mouse support in the TUI (scroll, click).
TUI_MOUSE=false

# Force the compact single-line TUI layout (useful for very small terminals).
TUI_COMPACT=false
